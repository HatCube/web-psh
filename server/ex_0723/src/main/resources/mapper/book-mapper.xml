<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace : 현재 Mapper XML이 어떤 Java 인터페이스와 연결되는지 지정 -->
<mapper namespace="com.korea.ex_0723.dao.BookDAO">
	<!-- 전체 조회 -->
	<select id="findAll" resultType="BookVO">
		SELECT id,title,author,category,price,stock FROM BOOKS
	</select>
	
	<!-- id를 통한 단건 조회 -->
	<select id="findById" resultType="BookVO">
		SELECT id,title,author,category,price,stock FROM BOOKS
		WHERE id = #{id}
	</select>
	
	<!-- 도서 등록 -->
	<insert id="insert">
		INSERT INTO BOOKS VALUES(#{title}, #{author}, #{category},#{price},#{stock})
	</insert>
	
	<!-- 도서 수정 -->
	<update id="update">
		UPDATE BOOKS SET
		title = #{title},
		author = #{author},
		category = #{category},
		price = #{price},
		stock = #{stock}
		WHERE ID = #{id}
	</update>
	
	<!-- 도서 삭제 -->
	<delete id="delete">
		delete from books where id = #{id}
	</delete>
	
	<!-- 카테고리 조건 조회 -->
	<select id="findByCategory" resultType="BookVO">
		select * from books where category = #{category}
	</select>
	
	<!-- 특정 문자열을 포함하는 조건 조회 -->
	<select id="findByTitle" resultType="BookVO">
		SELECT * FROM BOOKS WHERE TITLE LIKE CONCAT('%', #{title}, '%')
	</select>
	
	<!-- 전체 도서 개수 -->
	<select id="count" resultType="int">
		select count(*) from books
	</select>
	
	<!-- 저자에 따른 책 조회 -->
	<select id="findByAuthor" resultType="BookVO">
		select * from book
		<where> 
			<if test="author != null">
				 author = #{author}
			</if>
		</where>
	</select>
	
	<!-- 정렬 조건을 사용자가 선택하는 경우 -->
	<select id="findAllOrder" resultType="BookVO">
		select * from books
		<choose>
			<when test="sort == 'priceDesc'">
				ORDER BY price Desc
			</when>
			<when test="sort == 'titleAsc'">
				ORDER BY title Asc
			</when>
			<otherwise>
				ORDER BY id Desc
			</otherwise>
		</choose>
	</select>
	
</mapper>






